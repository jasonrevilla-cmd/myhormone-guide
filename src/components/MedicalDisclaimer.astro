---
interface Props {
  variant?: 'inline' | 'banner';
}
const { variant = 'inline' } = Astro.props;
---

{variant === 'banner' ? (
  <aside
    role="note"
    aria-label="Medical disclaimer"
    class="bg-warm-50 border border-warm-200 rounded-xl p-5 my-8 flex gap-4"
  >
    <svg class="w-5 h-5 text-amber-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
    </svg>
    <div>
      <p class="text-sm font-semibold text-navy-700 mb-1">Medical Disclaimer</p>
      <p class="text-sm text-gray-600 leading-relaxed">
        The content on this site is for educational purposes only and is not intended as medical advice.
        Always consult a qualified healthcare provider before starting, changing, or stopping any hormone
        therapy. Individual results vary.
      </p>
    </div>
  </aside>
) : (
  <p class="text-sm text-gray-500 italic border-t border-gray-200 pt-6 mt-8">
    <strong class="not-italic text-gray-600">Medical Disclaimer:</strong>{' '}
    The content on this site is for educational purposes only and is not intended as medical advice.
    Always consult a qualified healthcare provider before starting, changing, or stopping any hormone
    therapy. Individual results vary.
  </p>
)}
