---
interface Props {
  headline?: string;
  subheadline?: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
}

const {
  headline = "Understand Your Hormones.\nFeel Like Yourself Again.",
  subheadline = "The most trusted patient education resource for Bioidentical Hormone Replacement Therapy — evidence-based, empathetic, and built for real people.",
  primaryCta = { label: 'Check My Symptoms', href: '/tools/hormone-symptom-checker/' },
  secondaryCta = { label: 'What Is BHRT?', href: '/bhrt-fundamentals/' },
} = Astro.props;

const trustSignals = [
  { icon: 'check', text: 'Evidence-based content' },
  { icon: 'user', text: 'Written for patients, not clinicians' },
  { icon: 'shield', text: 'No sponsored diagnoses' },
];
---

<section class="relative overflow-hidden bg-gradient-to-br from-navy-700 via-navy-600 to-navy-800">
  <!-- Decorative background circles (CSS only, no images) -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <div class="absolute -top-24 -right-24 w-96 h-96 bg-teal-400 opacity-10 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-16 -left-16 w-80 h-80 bg-teal-300 opacity-8 rounded-full blur-2xl"></div>
    <div class="absolute top-1/2 left-1/3 w-64 h-64 bg-navy-400 opacity-20 rounded-full blur-3xl"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
    <div class="max-w-3xl">
      <!-- Eyebrow badge -->
      <div class="inline-flex items-center gap-2 bg-teal-400/20 border border-teal-400/30 text-teal-300 text-sm font-medium px-3 py-1 rounded-full mb-6">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
          <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
        </svg>
        Free Patient Education Resource
      </div>

      <!-- Headline -->
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
        {headline.split('\n').map((line, i) => (
          <>
            {i > 0 && <br />}
            {i === 1 ? <span class="text-teal-300">{line}</span> : line}
          </>
        ))}
      </h1>

      <!-- Subheadline -->
      <p class="text-lg sm:text-xl text-navy-100 leading-relaxed mb-8 max-w-2xl">
        {subheadline}
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 mb-12">
        <a
          href={primaryCta.href}
          class="inline-flex items-center justify-center gap-2 bg-teal-400 hover:bg-teal-300 text-white font-semibold text-base px-8 py-3.5 rounded-full shadow-lg transition-colors btn-pulse"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
          </svg>
          {primaryCta.label}
        </a>
        <a
          href={secondaryCta.href}
          class="inline-flex items-center justify-center gap-2 border-2 border-white/30 hover:border-white/60 text-white font-semibold text-base px-8 py-3.5 rounded-full transition-colors"
        >
          {secondaryCta.label}
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      </div>

      <!-- Trust signals -->
      <div class="flex flex-wrap gap-x-6 gap-y-3">
        {trustSignals.map((signal) => (
          <div class="flex items-center gap-2 text-navy-200 text-sm">
            <svg class="w-4 h-4 text-teal-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              {signal.icon === 'check' && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>}
              {signal.icon === 'user' && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>}
              {signal.icon === 'shield' && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>}
            </svg>
            {signal.text}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
