---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import '../styles/global.css';

interface BreadcrumbItem {
  label: string;
  href: string;
}

interface Props {
  title: string;
  description: string;
  breadcrumbs?: BreadcrumbItem[];
  canonicalUrl?: string;
  ogType?: 'website' | 'article';
  publishDate?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  breadcrumbs,
  canonicalUrl,
  ogType = 'website',
  publishDate,
  ogImage,
  noindex = false,
} = Astro.props;

const SITE_URL = 'https://www.myhormoneguide.com'; // Keep in sync with astro.config.mjs

// GA4 — only injected during production builds (not local dev)
const ga4Id = import.meta.env.GA4_MEASUREMENT_ID as string | undefined;
const isProd = import.meta.env.PROD;
const fullTitle = title.includes('MyHormoneGuide') ? title : `${title} | MyHormoneGuide`;
const canonical = canonicalUrl ?? new URL(Astro.url.pathname, SITE_URL).href;

// BreadcrumbList JSON-LD — rendered in <head> for all pages that supply breadcrumbs
const breadcrumbSchema = breadcrumbs && breadcrumbs.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Home',
          item: SITE_URL,
        },
        ...breadcrumbs.map((crumb, index) => ({
          '@type': 'ListItem',
          position: index + 2,
          name: crumb.label,
          item: `${SITE_URL}${crumb.href}`,
        })),
      ],
    }
  : null;

// WebSite + Organization schemas — only on homepage
const isHomepage = Astro.url.pathname === '/';

const websiteSchema = isHomepage
  ? {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'MyHormoneGuide',
      url: SITE_URL,
      description: 'The most trusted patient education resource for Bioidentical Hormone Replacement Therapy.',
      potentialAction: {
        '@type': 'SearchAction',
        target: {
          '@type': 'EntryPoint',
          urlTemplate: `${SITE_URL}/search?q={search_term_string}`,
        },
        'query-input': 'required name=search_term_string',
      },
    }
  : null;

const organizationSchema = isHomepage
  ? {
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name: 'MyHormoneGuide',
      url: SITE_URL,
      logo: `${SITE_URL}/logo.png`,
      description: 'The most trusted patient education resource for Bioidentical Hormone Replacement Therapy',
      sameAs: [],
      contactPoint: {
        '@type': 'ContactPoint',
        email: 'hello@myhormoneguide.com',
        contactType: 'customer support',
      },
    }
  : null;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content="MyHormoneGuide" />
  {ogImage && <meta property="og:image" content={ogImage} />}
  {ogImage && <meta property="og:image:width" content="1200" />}
  {ogImage && <meta property="og:image:height" content="630" />}
  {publishDate && <meta property="article:published_time" content={publishDate} />}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  {ogImage && <meta name="twitter:image" content={ogImage} />}

  <!-- Favicon (SVG inline data URI for zero-dependency fallback) -->
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><circle cx='16' cy='16' r='15' fill='%231A3C5E'/><path d='M10 16C10 12 13 10 16 10C19 10 22 12 22 16C22 20 19 22 16 22' stroke='%232A9D8F' stroke-width='2' fill='none' stroke-linecap='round'/><circle cx='16' cy='22' r='2' fill='%232A9D8F'/></svg>" type="image/svg+xml" />

  <!-- Google Fonts: Inter — preconnect for performance -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <!-- Structured data -->
  {organizationSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
  )}
  {websiteSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  )}
  {breadcrumbSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  )}

  <!-- Slot for page-specific head content (extra schema, etc.) -->
  <slot name="head" />

  <!-- Google Analytics 4 — production only, skipped during local dev -->
  {isProd && ga4Id && (
    <Fragment>
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`} />
      <script define:vars={{ ga4Id }}>
        window.dataLayer = window.dataLayer || [];
        function gtag() { window.dataLayer.push(arguments); }
        gtag('js', new Date());
        gtag('config', ga4Id);
      </script>
    </Fragment>
  )}
</head>
<body class="bg-white text-gray-700 font-sans antialiased">
  <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 bg-teal-400 text-white px-4 py-2 rounded z-[100] font-medium">
    Skip to main content
  </a>

  <Header />

  {breadcrumbs && breadcrumbs.length > 0 && (
    <Breadcrumb items={breadcrumbs} />
  )}

  <main id="main-content">
    <slot />
  </main>

  <Footer />
</body>
</html>
