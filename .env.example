# Anthropic API Key — required for the daily content pipeline
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Google Analytics 4 Measurement ID — optional, only injected in production builds
# Get yours from: Google Analytics > Admin > Data Streams > your stream > Measurement ID
# Format: G-XXXXXXXXXX — leave blank or omit to disable analytics
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
