---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  clusterSlug: string;
  clusterLabel: string;
  intro: string;
  posts: CollectionEntry<'posts'>[];
  icon?: string;
}

const { title, description, clusterSlug, clusterLabel, intro, posts, icon = 'fundamentals' } = Astro.props;

const breadcrumbs = [{ label: clusterLabel, href: `/${clusterSlug}/` }];

// Sort posts by publish date, newest first
const sortedPosts = [...posts].sort((a, b) => {
  const da = a.data.publishDate instanceof Date ? a.data.publishDate : new Date(a.data.publishDate);
  const db = b.data.publishDate instanceof Date ? b.data.publishDate : new Date(b.data.publishDate);
  return db.getTime() - da.getTime();
});

// CollectionPage schema
const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: title,
  description,
  url: `https://myhormoneguide.com/${clusterSlug}/`,
  numberOfItems: posts.length,
  publisher: {
    '@type': 'Organization',
    name: 'MyHormoneGuide',
  },
};
---

<BaseLayout title={title} description={description} breadcrumbs={breadcrumbs}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />
  </Fragment>

  <!-- Hub header -->
  <div class="bg-gradient-to-br from-navy-600 to-navy-700 py-14">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href="/" class="inline-flex items-center gap-1 text-navy-200 hover:text-white text-sm mb-4 transition-colors">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        All Topics
      </a>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-4">{title}</h1>
      <p class="text-navy-100 text-lg leading-relaxed max-w-2xl">{intro}</p>
      <div class="mt-6 inline-flex items-center gap-2 bg-teal-400/20 text-teal-200 text-sm px-3 py-1 rounded-full">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
          <path d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z"/>
        </svg>
        {posts.length} {posts.length === 1 ? 'article' : 'articles'} in this guide
      </div>
    </div>
  </div>

  <!-- Post list -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    {sortedPosts.length > 0 ? (
      <ol class="space-y-4">
        {sortedPosts.map((post, index) => {
          const pubDate = post.data.publishDate instanceof Date
            ? post.data.publishDate
            : new Date(post.data.publishDate);
          return (
            <li>
              <a
                href={`/${post.slug}/`}
                class="group flex items-start gap-4 p-5 rounded-2xl border border-navy-100 bg-white hover:border-teal-300 hover:shadow-md transition-all duration-200"
              >
                <!-- Number badge -->
                <span class="flex-shrink-0 w-9 h-9 rounded-full bg-navy-50 group-hover:bg-teal-50 text-navy-400 group-hover:text-teal-600 font-bold text-sm flex items-center justify-center transition-colors">
                  {String(index + 1).padStart(2, '0')}
                </span>

                <div class="flex-1 min-w-0">
                  <h2 class="font-semibold text-navy-700 group-hover:text-teal-600 text-base sm:text-lg mb-1 transition-colors leading-snug">
                    {post.data.title}
                  </h2>
                  <p class="text-sm text-gray-500 leading-relaxed line-clamp-2 mb-2">
                    {post.data.description}
                  </p>
                  <div class="flex items-center gap-3 text-xs text-gray-400">
                    {post.data.readingTime && (
                      <span class="flex items-center gap-1">
                        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                        {post.data.readingTime} min
                      </span>
                    )}
                    <time datetime={pubDate.toISOString()}>
                      {new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'short', day: 'numeric' }).format(pubDate)}
                    </time>
                  </div>
                </div>

                <svg class="w-5 h-5 text-navy-300 group-hover:text-teal-400 flex-shrink-0 mt-1 group-hover:translate-x-1 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </a>
            </li>
          );
        })}
      </ol>
    ) : (
      <div class="text-center py-20">
        <svg class="w-12 h-12 text-navy-200 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
        </svg>
        <p class="text-navy-400 font-medium mb-1">Articles coming soon</p>
        <p class="text-sm text-gray-400">New content is published daily. Check back tomorrow.</p>
      </div>
    )}

    <!-- Newsletter CTA at bottom of cluster -->
    <div class="mt-16 bg-gradient-to-r from-navy-600 to-navy-700 rounded-2xl p-8 text-center">
      <h2 class="text-2xl font-bold text-white mb-3">Want more on {clusterLabel}?</h2>
      <p class="text-navy-200 mb-6">Get weekly insights straight to your inbox — free, evidence-based, no spam.</p>
      <a href="/#newsletter" class="inline-flex items-center gap-2 bg-teal-400 hover:bg-teal-300 text-white font-semibold px-6 py-3 rounded-full transition-colors">
        Subscribe to the Newsletter →
      </a>
    </div>
  </div>
</BaseLayout>
