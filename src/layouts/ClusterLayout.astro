---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  clusterSlug: string;
  clusterLabel: string;
  intro: string;
  posts: CollectionEntry<'posts'>[];
  icon?: string;
}

const { title, description, clusterSlug, clusterLabel, intro, posts, icon = 'fundamentals' } = Astro.props;

const breadcrumbs = [{ label: clusterLabel, href: `/${clusterSlug}/` }];

const sortedPosts = [...posts].sort((a, b) => {
  const da = a.data.publishDate instanceof Date ? a.data.publishDate : new Date(a.data.publishDate);
  const db = b.data.publishDate instanceof Date ? b.data.publishDate : new Date(b.data.publishDate);
  return db.getTime() - da.getTime();
});

// CollectionPage schema
const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: title,
  description,
  url: `https://www.myhormoneguide.com/${clusterSlug}/`,
  numberOfItems: posts.length,
  publisher: {
    '@type': 'Organization',
    name: 'MyHormoneGuide',
  },
};

// Related clusters
const CLUSTER_META: Record<string, { label: string; href: string; desc: string }> = {
  'bhrt-fundamentals': { label: 'BHRT Fundamentals', href: '/bhrt-fundamentals/', desc: 'Plain-English intro to bioidentical hormones — start here.' },
  'symptoms':          { label: 'Hormone Symptoms',  href: '/symptoms/',          desc: 'Identify the signs your hormones may be out of balance.' },
  'pellet-therapy':    { label: 'Pellet Therapy',    href: '/pellet-therapy/',    desc: 'How pellet implants work, what to expect, and costs.' },
  'for-women':         { label: 'BHRT for Women',    href: '/for-women/',         desc: 'Guides for women navigating perimenopause and menopause.' },
  'for-men':           { label: 'BHRT for Men',      href: '/for-men/',           desc: 'Testosterone and hormone therapy guides for men over 40.' },
  'costs':             { label: 'Costs & Insurance', href: '/find-bhrt-provider/', desc: 'What BHRT costs and how insurance works.' },
};

const RELATED_MAP: Record<string, string[]> = {
  'symptoms':          ['for-women', 'for-men', 'bhrt-fundamentals'],
  'pellet-therapy':    ['bhrt-fundamentals', 'for-women', 'costs'],
  'for-women':         ['symptoms', 'pellet-therapy', 'bhrt-fundamentals'],
  'for-men':           ['symptoms', 'pellet-therapy', 'bhrt-fundamentals'],
  'find-bhrt-provider':['pellet-therapy', 'costs', 'bhrt-fundamentals'],
};

const relatedClusters = (RELATED_MAP[clusterSlug] ?? [])
  .map(s => CLUSTER_META[s])
  .filter(Boolean);
---

<BaseLayout title={title} description={description} breadcrumbs={breadcrumbs}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />
  </Fragment>

  <!-- Hub header -->
  <div class="bg-gradient-to-br from-navy-600 to-navy-700 py-14">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href="/" class="inline-flex items-center gap-1 text-navy-200 hover:text-white text-sm mb-4 transition-colors">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        All Topics
      </a>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-4">{title}</h1>
      <p class="text-navy-100 text-lg leading-relaxed max-w-2xl">{intro}</p>
      <div class="mt-6 inline-flex items-center gap-2 bg-teal-400/20 text-teal-200 text-sm px-3 py-1 rounded-full">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
          <path d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z"/>
        </svg>
        {posts.length} {posts.length === 1 ? 'article' : 'articles'} in this guide
      </div>
    </div>
  </div>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    <!-- Article grid -->
    {sortedPosts.length > 0 ? (
      <section aria-labelledby="articles-heading">
        <h2 id="articles-heading" class="sr-only">Articles in {clusterLabel}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          {sortedPosts.map((post) => {
            const readTime = post.data.readingTime ?? 8;
            return (
              <a
                href={`/${post.slug}/`}
                class="group flex flex-col bg-white border border-navy-100 rounded-2xl p-6 hover:border-teal-300 hover:shadow-md transition-all duration-200"
              >
                <h2 class="font-semibold text-navy-700 group-hover:text-teal-600 text-base sm:text-lg leading-snug mb-2 transition-colors">
                  {post.data.title}
                </h2>
                <p class="text-sm text-gray-500 leading-relaxed line-clamp-2 flex-1 mb-4">
                  {post.data.description}
                </p>
                <div class="flex items-center justify-between mt-auto">
                  <span class="flex items-center gap-1 text-xs text-gray-400">
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    {readTime} min read
                  </span>
                  <span class="text-sm font-medium text-teal-600 group-hover:text-teal-500 flex items-center gap-1">
                    Read article
                    <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                  </span>
                </div>
              </a>
            );
          })}
        </div>
      </section>
    ) : (
      <div class="text-center py-20">
        <svg class="w-12 h-12 text-navy-200 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
        </svg>
        <p class="text-navy-400 font-medium mb-1">Articles coming soon</p>
        <p class="text-sm text-gray-400">New content is published daily. Check back tomorrow.</p>
      </div>
    )}

    <!-- Newsletter CTA -->
    <div class="mt-16 bg-gradient-to-r from-navy-600 to-navy-700 rounded-2xl p-8 text-center">
      <h2 class="text-2xl font-bold text-white mb-3">Want more on {clusterLabel}?</h2>
      <p class="text-navy-200 mb-6">Real answers for real hormones — delivered weekly. Join our growing community of patients. Free, no spam.</p>
      <a href="/#newsletter" class="inline-flex items-center gap-2 bg-teal-400 hover:bg-teal-300 text-white font-semibold px-6 py-3 rounded-full transition-colors">
        Subscribe to The Hormone Insider →
      </a>
    </div>

    <!-- Related clusters -->
    {relatedClusters.length > 0 && (
      <section aria-labelledby="related-heading" class="mt-14">
        <h2 id="related-heading" class="text-xl font-bold text-navy-700 mb-5">Related Topics</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          {relatedClusters.map((hub) => (
            <a
              href={hub.href}
              class="group block p-5 bg-white border border-navy-100 rounded-2xl hover:border-teal-300 hover:shadow-sm transition-all duration-200"
            >
              <p class="font-semibold text-navy-700 group-hover:text-teal-600 text-sm mb-1 transition-colors">
                {hub.label}
              </p>
              <p class="text-xs text-gray-400 leading-relaxed mb-3">{hub.desc}</p>
              <span class="text-xs font-medium text-teal-600 flex items-center gap-1">
                Explore
                <svg class="w-3 h-3 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </span>
            </a>
          ))}
        </div>
      </section>
    )}

  </div>
</BaseLayout>
