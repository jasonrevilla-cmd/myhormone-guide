---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import MedicalDisclaimer from '../components/MedicalDisclaimer.astro';
import EmailOptIn from '../components/EmailOptIn.astro';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, description, publishDate, cluster, readingTime, faqs, primaryKeyword, tags, howToSteps } = post.data;

// Breadcrumb: Home > Cluster Hub > Post Title
const clusterLabels: Record<string, string> = {
  'bhrt-fundamentals': 'BHRT Fundamentals',
  'pellet-therapy': 'Pellet Therapy',
  'hormone-imbalance-symptoms': 'Symptoms Guide',
  'womens-health': "Women's Health",
  'mens-health': "Men's Health",
  'finding-providers': 'Find a Provider',
  'costs-insurance': 'Find a Provider',
  'research-science': 'Research & Science',
  'lifestyle': 'Lifestyle & Optimization',
  'delivery-methods': 'Pellet Therapy',
};

const clusterHrefs: Record<string, string> = {
  'bhrt-fundamentals': '/bhrt-fundamentals/',
  'pellet-therapy': '/pellet-therapy/',
  'hormone-imbalance-symptoms': '/symptoms/',
  'womens-health': '/for-women/',
  'mens-health': '/for-men/',
  'finding-providers': '/find-bhrt-provider/',
  'costs-insurance': '/find-bhrt-provider/',
  'research-science': '/learn/',
  'lifestyle': '/learn/',
  'delivery-methods': '/pellet-therapy/',
};

const clusterLabel = clusterLabels[cluster] ?? cluster;
const clusterHref = clusterHrefs[cluster] ?? `/${cluster}/`;

const breadcrumbs = [
  { label: clusterLabel, href: clusterHref },
  { label: title, href: `/${post.slug}/` },
];

const pubDateISO = publishDate instanceof Date
  ? publishDate.toISOString()
  : new Date(publishDate).toISOString();

const pubDateDisplay = new Intl.DateTimeFormat('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
}).format(publishDate instanceof Date ? publishDate : new Date(publishDate));

const readTime = readingTime ?? 8;

const SITE_URL = 'https://www.myhormoneguide.com';
const postUrl  = `${SITE_URL}/${post.slug}/`;

const authorRef = {
  '@type': 'Person',
  name: 'Jason Revilla',
  url: `${SITE_URL}/about/`,
};
const publisherRef = {
  '@type': 'Organization',
  name: 'MyHormoneGuide',
  url: SITE_URL,
};

// ── 1. MedicalWebPage (replaces plain Article) ────────────────────────────
const clusterToCondition: Record<string, string> = {
  'bhrt-fundamentals':        'Bioidentical Hormone Replacement Therapy',
  'pellet-therapy':           'Hormone Pellet Therapy',
  'hormone-imbalance-symptoms': 'Hormone Imbalance',
  'womens-health':            'Female Hormone Imbalance',
  'mens-health':              'Low Testosterone',
  'finding-providers':        'Hormone Therapy',
  'costs-insurance':          'Hormone Therapy',
  'research-science':         'Bioidentical Hormone Replacement Therapy',
  'lifestyle':                'Hormonal Health',
  'delivery-methods':         'Hormone Therapy',
};
const conditionName = clusterToCondition[cluster] ?? 'Hormone Imbalance';

const medicalWebPageSchema = {
  '@context': 'https://schema.org',
  '@type': ['MedicalWebPage', 'Article'],
  headline: title,
  description,
  url: postUrl,
  datePublished: pubDateISO,
  dateModified: pubDateISO,
  author: authorRef,
  publisher: publisherRef,
  mainEntityOfPage: { '@type': 'WebPage', '@id': postUrl },
  medicalAudience: {
    '@type': 'MedicalAudience',
    audienceType: 'Patient',
    healthCondition: {
      '@type': 'MedicalCondition',
      name: conditionName,
    },
  },
  about: {
    '@type': 'MedicalCondition',
    name: conditionName,
  },
  mentions: (tags ?? []).map((tag) => ({
    '@type': 'DefinedTerm',
    name: tag,
  })),
};

// ── 2. FAQPage ────────────────────────────────────────────────────────────
const faqSchema = faqs && faqs.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqs.map((faq) => ({
        '@type': 'Question',
        name: faq.question,
        acceptedAnswer: { '@type': 'Answer', text: faq.answer },
      })),
    }
  : null;

// ── 3. HowTo — fires only when howToSteps are present in frontmatter ──────
const howToSchema = howToSteps && howToSteps.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'HowTo',
      name: title,
      description,
      author: authorRef,
      publisher: publisherRef,
      step: howToSteps.map((s, i) => ({
        '@type': 'HowToStep',
        position: i + 1,
        name: s.name,
        text: s.text,
      })),
    }
  : null;

// ── 4. Speakable — targets intro paragraph and FAQ section ────────────────
const speakableSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': postUrl,
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: faqs && faqs.length > 0
      ? ['#post-intro', '.faq-wrapper']
      : ['#post-intro'],
  },
};

// ── 5. DefinedTerm — fires on "What Is / What Are" titles ─────────────────
const definedTermRaw = title.match(/^What (?:Is|Are) (.+?)(?:[?:—,]|$)/i)?.[1] ?? '';
const definedTermName = definedTermRaw
  .replace(/\s+Made From\s*$/i, '')
  .replace(/\s+A Complete .+$/i, '')
  .replace(/\s+Everything .+$/i, '')
  .replace(/\s+Explained\s*$/i, '')
  .trim();

const definedTermSchema = definedTermName
  ? {
      '@context': 'https://schema.org',
      '@type': 'DefinedTerm',
      '@id': `${postUrl}#term`,
      name: definedTermName,
      description,
      inDefinedTermSet: {
        '@type': 'DefinedTermSet',
        name: 'BHRT & Hormone Health Glossary',
        url: SITE_URL,
      },
    }
  : null;

// og:image — resolves to /images/posts/{slug}.jpg once images are generated
const ogImage = `https://www.myhormoneguide.com/images/posts/${post.slug}.jpg`;

// "More in [Cluster]" — 3 other posts from the same cluster
const allPosts = await getCollection('posts');
const morePosts = allPosts
  .filter(p => p.data.cluster === cluster && p.slug !== post.slug)
  .sort((a, b) => {
    const da = a.data.publishDate instanceof Date ? a.data.publishDate : new Date(a.data.publishDate);
    const db = b.data.publishDate instanceof Date ? b.data.publishDate : new Date(b.data.publishDate);
    return db.getTime() - da.getTime();
  })
  .slice(0, 3);
---

<BaseLayout
  title={title}
  description={description}
  breadcrumbs={breadcrumbs}
  ogType="article"
  publishDate={pubDateISO}
  ogImage={ogImage}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(medicalWebPageSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(speakableSchema)} />
    {faqSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    )}
    {howToSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
    )}
    {definedTermSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(definedTermSchema)} />
    )}
  </Fragment>

  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10 lg:py-14">
    <!-- Post header -->
    <header class="mb-10">
      <div class="flex flex-wrap items-center gap-3 mb-5">
        <!-- Cluster badge -->
        <a
          href={clusterHref}
          class="inline-flex items-center gap-1.5 bg-teal-50 text-teal-700 hover:bg-teal-100 text-xs font-semibold px-3 py-1 rounded-full uppercase tracking-wide transition-colors"
        >
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path fill-rule="evenodd" d="M17.707 9.293a1 1 0 010 1.414l-7 7a1 1 0 01-1.414 0l-7-7A.997.997 0 012 10V5a3 3 0 013-3h5c.256 0 .512.098.707.293l7 7zM5 6a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/>
          </svg>
          {clusterLabel}
        </a>

        <!-- Reading time -->
        <span class="reading-time-badge">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          {readTime} min read
        </span>

        <!-- Publish date -->
        <time datetime={pubDateISO} class="text-sm text-gray-400">{pubDateDisplay}</time>
      </div>

      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-navy-600 leading-tight mb-4">
        {title}
      </h1>

      <p id="post-intro" class="text-lg text-gray-500 leading-relaxed max-w-2xl">{description}</p>

      <!-- Author byline -->
      <div class="flex items-center gap-3 mt-6 pt-6 border-t border-gray-100">
        <div class="flex-shrink-0 w-10 h-10 rounded-full bg-navy-600 flex items-center justify-center">
          <span class="text-white font-bold text-sm tracking-wide">JR</span>
        </div>
        <div>
          <p class="font-semibold text-navy-700 text-sm leading-tight">Jason Revilla</p>
          <p class="text-xs text-gray-400">Founder &amp; Lead Researcher, MyHormoneGuide</p>
        </div>
      </div>
    </header>

    <!-- Medical disclaimer banner at top -->
    <MedicalDisclaimer variant="banner" />

    <!-- Article body — Tailwind Typography prose -->
    <div class="prose prose-lg max-w-none mt-10
      prose-headings:font-bold
      prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4 prose-h2:pb-2 prose-h2:border-b prose-h2:border-navy-100
      prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
      prose-p:leading-relaxed
      prose-li:leading-relaxed
      prose-table:text-sm
      prose-th:bg-navy-50 prose-th:text-navy-700
      prose-strong:text-navy-700
    ">
      <slot />
    </div>

    <!-- Inline newsletter opt-in -->
    <EmailOptIn variant="inline" />

    <!-- Medical disclaimer footer -->
    <MedicalDisclaimer variant="inline" />

    <!-- More in [Cluster] -->
    {morePosts.length > 0 && (
      <aside aria-labelledby="more-in-cluster" class="mt-12 pt-10 border-t border-gray-100">
        <h2 id="more-in-cluster" class="text-lg font-bold text-navy-700 mb-5">
          More in {clusterLabel}
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          {morePosts.map((p) => {
            const rt = p.data.readingTime ?? 8;
            return (
              <a
                href={`/${p.slug}/`}
                class="group flex flex-col bg-white border border-navy-100 rounded-xl p-5 hover:border-teal-300 hover:shadow-sm transition-all duration-200"
              >
                <h3 class="font-semibold text-navy-700 group-hover:text-teal-600 text-sm leading-snug mb-2 transition-colors flex-1">
                  {p.data.title}
                </h3>
                <div class="flex items-center justify-between mt-3">
                  <span class="flex items-center gap-1 text-xs text-gray-400">
                    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    {rt} min
                  </span>
                  <span class="text-xs font-medium text-teal-600 flex items-center gap-1">
                    Read
                    <svg class="w-3 h-3 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                  </span>
                </div>
              </a>
            );
          })}
        </div>
        <a href={clusterHref} class="inline-flex items-center gap-1 text-sm text-teal-600 hover:text-teal-500 font-medium mt-5">
          View all {clusterLabel} articles →
        </a>
      </aside>
    )}

    <!-- Post footer nav -->
    <nav class="mt-10 pt-8 border-t border-gray-100 flex items-center justify-between gap-4">
      <a href={clusterHref} class="inline-flex items-center gap-2 text-sm text-teal-600 hover:text-teal-500 font-medium">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Back to {clusterLabel}
      </a>
      <a href="/find-bhrt-provider/" class="inline-flex items-center gap-2 text-sm bg-navy-600 hover:bg-navy-700 text-white font-semibold px-5 py-2 rounded-full transition-colors">
        Find a Provider
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
    </nav>
  </article>
</BaseLayout>

<style>
  /* References section — muted, academic styling */
  :global(.prose h2:has(+ p > a[href*="pubmed"]),
          .prose h2:has(+ p > a[href*="endocrine"]),
          .prose h2:has(+ p > a[href*="menopause"]),
          .prose h2:has(+ p > a[href*="mayoclinic"]),
          .prose h2:has(+ p > a[href*="fda.gov"])) {
    /* broad selector fallback handled below */
  }
  :global(.prose h2 + ol li, .prose h2 + p) {
    /* default prose handles these */
  }
  /* References heading — visually distinct from body H2s */
  :global(.references-section) {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 2px solid #E2E8F0;
  }
  :global(.references-section h2) {
    font-size: 1rem !important;
    font-weight: 600 !important;
    color: #64748B !important;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border-bottom: none !important;
    margin-bottom: 1rem !important;
  }
  :global(.references-section ol, .references-section p) {
    font-size: 0.8125rem !important;
    color: #94A3B8 !important;
    line-height: 1.6 !important;
  }
  :global(.references-section a) {
    color: #94A3B8 !important;
    text-decoration: underline;
    word-break: break-all;
  }
  :global(.references-section a:hover) {
    color: #2A9D8F !important;
  }

  /* FAQ section within MDX prose — distinct visual treatment */
  :global(.prose h2:has(+ h3)) {
    /* targets the FAQ heading when followed directly by H3s */
  }

  /* Override prose for FAQ section container — added by generate-post.js MDX */
  :global(.faq-wrapper) {
    background: linear-gradient(135deg, #EEF2F7 0%, #E8F7F6 100%);
    border-radius: 1rem;
    padding: 2rem;
    margin-top: 3rem !important;
  }
  :global(.faq-wrapper h2) {
    margin-top: 0 !important;
    border-bottom: 2px solid #2A9D8F;
    padding-bottom: 0.75rem;
  }
</style>
