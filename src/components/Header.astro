---
const navItems = [
  { label: 'Start Here',      href: '/start-here/' },
  { label: 'Symptoms',        href: '/symptoms/' },
  { label: 'Pellet Therapy',  href: '/pellet-therapy/' },
  { label: 'For Women',       href: '/for-women/' },
  { label: 'For Men',         href: '/for-men/' },
  { label: 'Find a Provider', href: '/find-bhrt-provider/' },
  { label: 'BHRT Basics',     href: '/bhrt-fundamentals/' },
  { label: 'Tools',           href: '/tools/' },
];

const resourceItems = [
  { label: 'BHRT Glossary',       href: '/bhrt-glossary/',                  desc: '50+ terms defined' },
  { label: 'Research Timeline',   href: '/bhrt-research/',                   desc: '2002–present studies' },
  { label: 'BHRT Statistics',     href: '/bhrt-statistics/',                 desc: 'Cited data & figures' },
  { label: 'Editorial Standards', href: '/about/editorial-standards/',       desc: 'How we work' },
];

const currentPath = Astro.url.pathname;
const resourcesActive = resourceItems.some(r => currentPath.startsWith(r.href));
---

<header class="bg-navy-600 sticky top-0 z-50 shadow-lg">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group" aria-label="MyHormoneGuide home">
        <svg class="w-8 h-8 text-teal-400 group-hover:text-teal-300 transition-colors" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <circle cx="16" cy="16" r="14" stroke="currentColor" stroke-width="2"/>
          <path d="M10 16 C10 12 13 10 16 10 C19 10 22 12 22 16 C22 20 19 22 16 22" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          <circle cx="16" cy="22" r="2" fill="currentColor"/>
          <path d="M13 16 L19 16 M16 13 L16 19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <span class="text-white font-bold text-lg tracking-tight">
          MyHormone<span class="text-teal-400">Guide</span>
        </span>
      </a>

      <!-- Desktop nav -->
      <div class="hidden lg:flex items-center gap-1">
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'px-3 py-2 rounded-md text-sm font-medium transition-colors',
              currentPath.startsWith(item.href)
                ? 'bg-navy-700 text-teal-300'
                : 'text-navy-100 hover:bg-navy-700 hover:text-white',
            ]}
          >
            {item.label}
          </a>
        ))}

        <!-- Resources dropdown -->
        <div class="relative" id="resources-wrapper">
          <button
            id="resources-btn"
            aria-haspopup="true"
            aria-expanded="false"
            aria-controls="resources-menu"
            class:list={[
              'px-3 py-2 rounded-md text-sm font-medium transition-colors flex items-center gap-1',
              resourcesActive
                ? 'bg-navy-700 text-teal-300'
                : 'text-navy-100 hover:bg-navy-700 hover:text-white',
            ]}
          >
            Resources
            <svg id="resources-chevron" class="w-3.5 h-3.5 transition-transform duration-150" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>

          <div
            id="resources-menu"
            role="menu"
            aria-labelledby="resources-btn"
            class="hidden absolute top-full right-0 mt-1 w-56 bg-white rounded-xl shadow-xl border border-gray-100 py-1.5 z-50"
          >
            {resourceItems.map(item => (
              <a
                href={item.href}
                role="menuitem"
                class:list={[
                  'flex flex-col px-4 py-2.5 hover:bg-navy-50 transition-colors',
                  currentPath.startsWith(item.href) ? 'bg-teal-50' : '',
                ]}
              >
                <span class:list={[
                  'text-sm font-medium',
                  currentPath.startsWith(item.href) ? 'text-teal-600' : 'text-navy-700',
                ]}>{item.label}</span>
                <span class="text-xs text-gray-400">{item.desc}</span>
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Desktop CTA -->
      <a
        href="/find-bhrt-provider/"
        class="hidden lg:inline-flex items-center gap-1.5 bg-teal-400 hover:bg-teal-300 text-white text-sm font-semibold px-4 py-2 rounded-full transition-colors"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        Find My Provider
      </a>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden text-navy-100 hover:text-white p-2 rounded-md"
        aria-label="Toggle mobile menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="hamburger-icon" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="close-icon" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden lg:hidden pb-4">
      <div class="flex flex-col gap-1">
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'px-3 py-2.5 rounded-md text-sm font-medium transition-colors',
              currentPath.startsWith(item.href)
                ? 'bg-navy-700 text-teal-300'
                : 'text-navy-100 hover:bg-navy-700 hover:text-white',
            ]}
          >
            {item.label}
          </a>
        ))}

        <!-- Resources group in mobile -->
        <div class="mt-1 pt-2 border-t border-navy-500">
          <p class="px-3 pb-1 text-xs font-semibold text-navy-400 uppercase tracking-wider">Resources</p>
          {resourceItems.map(item => (
            <a
              href={item.href}
              class:list={[
                'px-3 py-2.5 rounded-md text-sm font-medium transition-colors flex items-center justify-between',
                currentPath.startsWith(item.href)
                  ? 'bg-navy-700 text-teal-300'
                  : 'text-navy-100 hover:bg-navy-700 hover:text-white',
              ]}
            >
              {item.label}
              <span class="text-xs text-navy-400">{item.desc}</span>
            </a>
          ))}
        </div>

        <a
          href="/find-bhrt-provider/"
          class="mt-2 text-center bg-teal-400 hover:bg-teal-300 text-white text-sm font-semibold px-4 py-2.5 rounded-full transition-colors"
        >
          Find My Provider
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  // Mobile menu toggle
  const mobileBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const hamburgerIcon = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  mobileBtn?.addEventListener('click', () => {
    const isOpen = !mobileMenu?.classList.contains('hidden');
    mobileMenu?.classList.toggle('hidden', isOpen);
    hamburgerIcon?.classList.toggle('hidden', !isOpen);
    closeIcon?.classList.toggle('hidden', isOpen);
    mobileBtn.setAttribute('aria-expanded', String(!isOpen));
  });

  // Resources dropdown
  const resourcesBtn = document.getElementById('resources-btn');
  const resourcesMenu = document.getElementById('resources-menu');
  const resourcesChevron = document.getElementById('resources-chevron');

  function openResources() {
    resourcesMenu?.classList.remove('hidden');
    resourcesBtn?.setAttribute('aria-expanded', 'true');
    resourcesChevron?.classList.add('rotate-180');
  }

  function closeResources() {
    resourcesMenu?.classList.add('hidden');
    resourcesBtn?.setAttribute('aria-expanded', 'false');
    resourcesChevron?.classList.remove('rotate-180');
  }

  resourcesBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isOpen = resourcesBtn.getAttribute('aria-expanded') === 'true';
    isOpen ? closeResources() : openResources();
  });

  // Close on outside click
  document.addEventListener('click', closeResources);

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeResources();
  });

  // Keep open when clicking inside the menu
  resourcesMenu?.addEventListener('click', (e) => e.stopPropagation());
</script>
