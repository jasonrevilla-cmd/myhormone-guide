---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allPosts = await getCollection('posts');
const providerPosts = allPosts
  .filter((p) => p.data.cluster === 'finding-providers')
  .sort((a, b) => {
    const da = a.data.publishDate instanceof Date ? a.data.publishDate : new Date(a.data.publishDate);
    const db = b.data.publishDate instanceof Date ? b.data.publishDate : new Date(b.data.publishDate);
    return db.getTime() - da.getTime();
  });

const breadcrumbs = [{ label: 'Find a Provider', href: '/find-bhrt-provider/' }];

const credentials = [
  { title: 'Board Certification', desc: 'Look for board-certified physicians in OB/GYN, internal medicine, endocrinology, or family medicine with additional hormone training.' },
  { title: 'BHRT-Specific Training', desc: 'Ask about training through organizations like A4M (American Academy of Anti-Aging Medicine), ACAM, or Institute for Functional Medicine.' },
  { title: 'Compounding Pharmacy Relationships', desc: 'Quality providers work with accredited compounding pharmacies (look for PCAB accreditation) to ensure medication quality.' },
  { title: 'Comprehensive Testing', desc: 'A good provider orders thorough baseline bloodwork — not just one or two markers. Expect testing for estrogen, progesterone, testosterone, DHEA, cortisol, and thyroid.' },
  { title: 'Follow-Up Protocol', desc: 'Legitimate BHRT practices include scheduled follow-up visits and re-testing to optimize dosing. Avoid anyone who never adjusts your protocol.' },
];

const redFlags = [
  'Prescribes without comprehensive baseline testing',
  'Offers a single one-size-fits-all protocol',
  'Makes guarantees about specific results',
  'Pressure to purchase supplements or products from their practice',
  'No follow-up bloodwork scheduled',
  'Doesn\'t explain the risks along with the benefits',
];

const questions = [
  'What hormone testing do you order before starting treatment?',
  'What delivery methods do you offer, and how do you determine which is right for me?',
  'Which compounding pharmacy do you use, and is it PCAB-accredited?',
  'How often will we retest my levels after starting?',
  'What are the risks I should be aware of for my specific situation?',
  'Do you work with a functional medicine approach, or is this purely hormone replacement?',
  'What is your experience with patients at my age and with my symptom profile?',
];
---

<BaseLayout
  title="Find a BHRT Provider Near You"
  description="How to find a qualified BHRT provider: credentials to look for, questions to ask at your first consultation, and red flags to avoid."
  breadcrumbs={breadcrumbs}
>
  <!-- Header -->
  <div class="bg-gradient-to-br from-navy-600 to-navy-700 py-14">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-4">
        Find a BHRT Provider
      </h1>
      <p class="text-navy-100 text-lg leading-relaxed max-w-2xl">
        Choosing the right provider is the most important decision you'll make on your BHRT journey.
        Here's exactly what to look for — and what to avoid.
      </p>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    <!-- Provider directory CTA -->
    <div class="bg-teal-50 border border-teal-200 rounded-2xl p-8 mb-12 text-center">
      <svg class="w-10 h-10 text-teal-400 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
      </svg>
      <h2 class="text-2xl font-bold text-navy-700 mb-3">Provider Directory</h2>
      <p class="text-gray-600 mb-6 max-w-lg mx-auto">
        Our curated directory of BHRT-specialized clinics is coming soon. In the meantime, use the guidance below to evaluate any provider in your area.
      </p>
      <a href="/tools/provider-finder/" class="inline-flex items-center gap-2 bg-teal-400 hover:bg-teal-500 text-white font-semibold px-6 py-3 rounded-full transition-colors">
        Explore Provider Finder Tool →
      </a>
    </div>

    <!-- What credentials to look for -->
    <section aria-labelledby="credentials-heading" class="mb-14">
      <h2 id="credentials-heading" class="text-2xl font-bold text-navy-600 mb-2 pb-2 border-b border-navy-100">
        Credentials to Look For
      </h2>
      <p class="text-gray-500 mb-6">Not every provider who offers BHRT has specialized training in it. Here's what separates experienced practitioners from those who dabble.</p>
      <div class="space-y-4">
        {credentials.map((item, i) => (
          <div class="flex gap-4 p-5 bg-white rounded-xl border border-navy-100">
            <div class="w-8 h-8 bg-teal-400 text-white rounded-full flex items-center justify-center text-sm font-bold flex-shrink-0">
              {i + 1}
            </div>
            <div>
              <h3 class="font-semibold text-navy-700 mb-1">{item.title}</h3>
              <p class="text-sm text-gray-500 leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Questions to ask -->
    <section aria-labelledby="questions-heading" class="mb-14">
      <h2 id="questions-heading" class="text-2xl font-bold text-navy-600 mb-2 pb-2 border-b border-navy-100">
        Questions to Ask at Your First Consultation
      </h2>
      <p class="text-gray-500 mb-6">A confident provider welcomes these questions. Their answers will tell you everything you need to know.</p>
      <ul class="space-y-3">
        {questions.map((q) => (
          <li class="flex items-start gap-3 p-4 bg-navy-50 rounded-xl">
            <svg class="w-5 h-5 text-teal-400 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span class="text-sm text-navy-700">{q}</span>
          </li>
        ))}
      </ul>
    </section>

    <!-- Red flags -->
    <section aria-labelledby="redflags-heading" class="mb-14">
      <h2 id="redflags-heading" class="text-2xl font-bold text-navy-600 mb-2 pb-2 border-b border-navy-100">
        Red Flags to Watch For
      </h2>
      <div class="bg-red-50 border border-red-100 rounded-xl p-6">
        <ul class="space-y-3">
          {redFlags.map((flag) => (
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-red-400 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
              </svg>
              <span class="text-sm text-red-700">{flag}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Dynamic post listing: Finding Providers + Costs & Insurance -->
    {providerPosts.length > 0 && (
      <section aria-labelledby="articles-heading" class="mt-14">
        <h2 id="articles-heading" class="text-2xl font-bold text-navy-600 mb-2 pb-2 border-b border-navy-100">
          Provider &amp; Cost Guides
        </h2>
        <p class="text-gray-500 mb-6">In-depth articles on finding a qualified provider and understanding BHRT costs.</p>
        <ol class="space-y-4">
          {providerPosts.map((post, index) => {
            const pubDate = post.data.publishDate instanceof Date
              ? post.data.publishDate
              : new Date(post.data.publishDate);
            return (
              <li>
                <a
                  href={`/${post.slug}/`}
                  class="group flex items-start gap-4 p-5 rounded-2xl border border-navy-100 bg-white hover:border-teal-300 hover:shadow-md transition-all duration-200"
                >
                  <span class="flex-shrink-0 w-9 h-9 rounded-full bg-navy-50 group-hover:bg-teal-50 text-navy-400 group-hover:text-teal-600 font-bold text-sm flex items-center justify-center transition-colors">
                    {String(index + 1).padStart(2, '0')}
                  </span>
                  <div class="flex-1 min-w-0">
                    <h3 class="font-semibold text-navy-700 group-hover:text-teal-600 text-base sm:text-lg mb-1 transition-colors leading-snug">
                      {post.data.title}
                    </h3>
                    <p class="text-sm text-gray-500 leading-relaxed line-clamp-2 mb-2">
                      {post.data.description}
                    </p>
                    <div class="flex items-center gap-3 text-xs text-gray-400">
                      {post.data.readingTime && (
                        <span class="flex items-center gap-1">
                          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                          </svg>
                          {post.data.readingTime} min
                        </span>
                      )}
                      <time datetime={pubDate.toISOString()}>
                        {new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'short', day: 'numeric' }).format(pubDate)}
                      </time>
                    </div>
                  </div>
                  <svg class="w-5 h-5 text-navy-300 group-hover:text-teal-400 flex-shrink-0 mt-1 group-hover:translate-x-1 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>
                </a>
              </li>
            );
          })}
        </ol>
      </section>
    )}

    <!-- Quick links -->
    <div class="mt-10 bg-navy-50 rounded-2xl p-8">
      <h2 class="text-xl font-bold text-navy-700 mb-4">Continue Your Research</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <a href="/learn/" class="block p-4 bg-white rounded-xl border border-navy-100 hover:border-teal-300 hover:shadow-sm transition-all">
          <p class="font-medium text-navy-700 text-sm mb-1">BHRT Fundamentals &amp; Research</p>
          <p class="text-xs text-gray-400">Understand BHRT before you book an appointment</p>
        </a>
        <a href="/tools/hormone-symptom-checker/" class="block p-4 bg-white rounded-xl border border-navy-100 hover:border-teal-300 hover:shadow-sm transition-all">
          <p class="font-medium text-navy-700 text-sm mb-1">Check Your Symptoms First</p>
          <p class="text-xs text-gray-400">Take our free symptom assessment quiz</p>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
