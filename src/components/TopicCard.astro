---
interface Props {
  title: string;
  description: string;
  href: string;
  icon: 'fundamentals' | 'pellet' | 'women' | 'men' | 'symptoms' | 'provider' | 'research' | 'costs';
  postCount?: number;
  accent?: string;
}

const { title, description, href, icon, postCount, accent = 'teal' } = Astro.props;

const icons: Record<string, string> = {
  fundamentals: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>`,
  pellet: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>`,
  women: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>`,
  men: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M13 10V3L4 14h7v7l9-11h-7z"/>`,
  symptoms: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>`,
  provider: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>`,
  research: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>`,
  costs: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
};

const accentClasses: Record<string, { bg: string; icon: string; badge: string }> = {
  teal:   { bg: 'bg-teal-50 group-hover:bg-teal-100',   icon: 'text-teal-400',  badge: 'bg-teal-100 text-teal-700' },
  navy:   { bg: 'bg-navy-50 group-hover:bg-navy-100',   icon: 'text-navy-400',  badge: 'bg-navy-100 text-navy-700' },
  warm:   { bg: 'bg-warm-50 group-hover:bg-warm-100',   icon: 'text-amber-500', badge: 'bg-warm-100 text-amber-700' },
};

const ac = accentClasses[accent] ?? accentClasses.teal;
---

<a
  href={href}
  class:list={[
    'group block rounded-2xl border border-navy-100 bg-white p-6',
    'hover:border-teal-300 hover:shadow-lg transition-all duration-200 tool-card',
  ]}
>
  <div class={`inline-flex p-3 rounded-xl mb-4 transition-colors ${ac.bg}`}>
    <svg class={`w-6 h-6 ${ac.icon}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
      <Fragment set:html={icons[icon] ?? icons.fundamentals} />
    </svg>
  </div>

  <h3 class="text-navy-600 font-bold text-lg mb-2 group-hover:text-teal-600 transition-colors">
    {title}
  </h3>

  <p class="text-gray-500 text-sm leading-relaxed mb-4">
    {description}
  </p>

  <div class="flex items-center justify-between">
    {postCount !== undefined && (
      <span class={`text-xs font-medium px-2 py-0.5 rounded-full ${ac.badge}`}>
        {postCount} {postCount === 1 ? 'article' : 'articles'}
      </span>
    )}
    <span class="text-teal-500 text-sm font-medium group-hover:translate-x-1 transition-transform inline-flex items-center gap-1 ml-auto">
      Explore →
    </span>
  </div>
</a>
