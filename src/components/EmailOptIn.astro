---
interface Props {
  variant?: 'section' | 'inline';
  headline?: string;
  subheadline?: string;
}

const {
  variant = 'section',
  headline = 'The Hormone Insider',
  subheadline = 'Real answers for real hormones — delivered weekly.',
} = Astro.props;
---

{variant === 'section' ? (
  <section id="newsletter" class="bg-gradient-to-r from-navy-600 to-navy-700 py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <!-- Icon -->
      <div class="inline-flex p-3 bg-teal-400/20 rounded-xl mb-5">
        <svg class="w-7 h-7 text-teal-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
      </div>

      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-3">{headline}</h2>
      <p class="text-navy-200 text-lg mb-2">{subheadline}</p>
      <p class="text-navy-300 text-sm mb-8">
        Join 4,000+ readers making informed decisions about their health. Free. No spam. Unsubscribe anytime.
      </p>

      <!-- Beehiiv inline embed -->
      <div class="max-w-md mx-auto">
        <script async src="https://subscribe-forms.beehiiv.com/v3/loader.js" data-beehiiv-form="dd84c3b5-9ecd-4401-9010-f56d1c093769"></script>
      </div>
    </div>
  </section>
) : (
  <aside class="bg-teal-50 border border-teal-200 rounded-xl p-6 my-8">
    <div class="flex gap-4">
      <div class="flex-shrink-0">
        <svg class="w-6 h-6 text-teal-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
      </div>
      <div>
        <p class="font-semibold text-navy-700 mb-1">The Hormone Insider — Free Weekly Newsletter</p>
        <p class="text-sm text-gray-600 mb-3">Real answers for real hormones, delivered weekly. Join 4,000+ readers. No spam, unsubscribe anytime.</p>
        <a href="/#newsletter" class="inline-flex items-center text-sm font-semibold text-teal-600 hover:text-teal-500">
          Subscribe free →
        </a>
      </div>
    </div>
  </aside>
)}
